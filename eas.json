      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_URL": "http://172.27.24.53:3000"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
